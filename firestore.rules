rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isProjectAdmin(projectKey) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.jiraProjectKey == projectKey &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /projects/{projectKey} {
      allow read: if isProjectAdmin(projectKey);
      allow write: if isProjectAdmin(projectKey);
      match /{document=**} {
        allow read, write: if isProjectAdmin(projectKey);
      }
    }
    
    match /workflows/{workflowId} {
      allow read: if isProjectAdmin(resource.data.projectId);
      allow create: if isProjectAdmin(request.resource.data.projectId);
      allow update, delete: if isProjectAdmin(resource.data.projectId);
    }
    
    match /executions/{executionId} {
      allow create: if isProjectAdmin(request.resource.data.projectId);
      allow read: if isProjectAdmin(resource.data.projectId);
    }
  }
}